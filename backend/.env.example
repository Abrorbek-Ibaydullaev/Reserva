# Copy this file to .env and fill in local values.
SECRET_KEY=change-me-to-any-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite by default for local development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# CORS
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# reCAPTCHA (optional — leave blank to skip locally)
RECAPTCHA_SECRET_KEY=

# Google Sign-In — OAuth 2.0 Web Client ID (same value as the frontend's
# VITE_GOOGLE_CLIENT_ID). Required for the POST /api/auth/google/ endpoint.
GOOGLE_CLIENT_ID=

# Cloudinary image storage (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
