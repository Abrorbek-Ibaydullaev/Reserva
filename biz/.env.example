# Copy to .env and fill in.
# Backend API origin (the biz app talks to the SAME Django backend).
VITE_API_BASE_URL=http://localhost:8000

# Google Sign-In — OAuth 2.0 Web Client ID (same value as the customer app
# and the backend GOOGLE_CLIENT_ID). Required for the Google login button.
VITE_GOOGLE_CLIENT_ID=

# reCAPTCHA v2 site key (optional — leave blank to skip locally).
# Needed in production because /api/auth/login/ verifies reCAPTCHA.
VITE_RECAPTCHA_SITE_KEY=
