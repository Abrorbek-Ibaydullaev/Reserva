  "static": {
    "about_title": "Biz haqimizda",
    "about_description": "Reserva mijozlarga ishonchli xizmatlarni topish va kam muammo bilan uchrashuvlarni bron qilishga yordam beradi. Bu sahifa tez orada missiyamiz, jamoa va xizmat ko'rsatadigan jamoatchiliklar haqida ko'proq ma'lumot beradi.",
    "contact_title": "Biz bilan bog'lanish",
    "contact_description": "Bron, biznes profili yoki hamkorlik bo'yicha savolingiz bormi? Bu sahifada tez orada to'g'ridan-to'g'ri qo'llab-quvvatlash kanallari va javob berish muddatlari bo'ladi.",
    "features_title": "Xususiyatlar",
    "features_description": "Xizmatlarni topish, real vaqtda bron qilish, mijoz eslat malari va biznes jadvali uchun Reserva xususiyatlarini o'rganing. Batafsil qo'llanma tez orada keladi.",
    "pricing_title": "Narxlar",
    "pricing_description": "Jismoniy shaxslar va bizneslar uchun oddiy va shaffof narxlar. Batafsil rejalari tez orada bo'ladi.",
    "help_title": "Yordam markazi",
    "help_description": "Bron, bekor qilish, hisob sozlamalari va boshqalar bo'yicha ko'p beriladigan savollarga javoblarni toping. To'liq yordam markazi yo'lda.",
    "blog_title": "Blog",
    "blog_description": "Reserva yangiliklari, xizmat ko'rsatuvchilar uchun maslahatlar va jamoa hikoyalaridan xabardor bo'ling. Maqolalar tez orada.",
    "careers_title": "Karyera",
    "careers_description": "Biz O'zbekiston uchun yetakchi bron platformasini quryapmiz va iste'dodli odamlarni qidirmoqdamiz. Ochiq lavozimlar tez orada ro'yxatga olinadi.",
    "press_title": "Matbuot",
    "press_description": "Media so'rovlar, matbuot to'plamlari va brend aktivlari. Hamkorlik va yoritish so'rovlari uchun kommunikatsiya jamoamizga murojaat qiling.",
